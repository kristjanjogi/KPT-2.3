def normalize_case_to_engine_input(case: dict[str, Any], meta: dict[str, Any]) -> dict[str, Any]:
    """
    Convert a demo case into the engine evaluation payload shape.

    v0.1 rule:
    - core schema stays stable
    - demo extensions may be passed through under a demo-only namespace
    """
    return {
        "input_ref": case["input_ref"],
        "output_ref": case["output_ref"],
        "candidate_output": {
            "content": case["candidate_output"]["content"],
            "content_type": case["candidate_output"]["content_type"],
            # demo extension fields may be retained separately
            "candidate_id": case["candidate_output"].get("candidate_id"),
            "parent_candidate_id": case["candidate_output"].get("parent_candidate_id"),
        },
        "context": {
            "zone": case["context"]["zone"],
            "profile": case["context"]["profile"],
            "deployment_mode": case["context"]["deployment_mode"],
            "execution_relevant": case["context"]["execution_relevant"],
            "user_visible": case["context"]["user_visible"],
            "downstream_target": case["context"]["downstream_target"],
            "route_type": case["route_type"],  # demo extension
        },
        "provenance": case.get("provenance", {}),
        "policy": {
            "policy_version": meta["policy_version"],
            "engine_version": meta["engine_version"],
        },
        "report_layer_extensions": {
            "case_id": case["case_id"],
            "title": case.get("title"),
            "safe_replacement": case.get("policy", {}).get("safe_replacement"),
            "allow_safe_replacement": case.get("policy", {}).get("allow_safe_replacement", False),
        },
    }


