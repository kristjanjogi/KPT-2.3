def build_summary_report(results: list[dict[str, Any]]) -> dict[str, Any]:
    """Produce overall demo summary."""
    total = len(results)
    passed = sum(1 for r in results if r["passed"])
    failed = total - passed

    return {
        "total_cases": total,
        "passed_cases": passed,
        "failed_cases": failed,
        "failed_case_ids": [r["case_id"] for r in results if not r["passed"]],
        "results": results,
    }


def print_console_summary(summary: dict[str, Any]) -> None:
    """Human-readable console output for the demo run."""
    print("KPT Reference Engine v0.1 Demo")
    print(f"Total cases:  {summary['total_cases']}")
    print(f"Passed cases: {summary['passed_cases']}")
    print(f"Failed cases: {summary['failed_cases']}")

    if summary["failed_case_ids"]:
        print("Failed case IDs:")
        for case_id in summary["failed_case_ids"]:
            print(f" - {case_id}")


def main() -> int:
    """
    Full demo runner order.

    Locked v0.1 order:
    1. prepare output directories
    2. load canonical demo cases
    3. normalize each case into engine input
    4. run engine
    5. flatten outputs
    6. compare expected vs actual
    7. write artifacts
    8. write summary report
    9. print console summary
    10. return pass/fail exit code
    """
    ensure_output_dirs()

    demo = load_demo_cases("reference-engine/demo_cases.yaml")
    meta = {
        "engine_version": demo["engine_version"],
        "policy_version": demo["policy_version"],
    }

    results = []

    for case in demo["cases"]:
        case_payload = normalize_case_to_engine_input(case, meta)
        engine_result = run_engine_for_case(case_payload)
        flattened = flatten_results(engine_result)
        comparison = compare_case_result(case, flattened)
        write_case_outputs(case, flattened, comparison)
        results.append(comparison)

    summary = build_summary_report(results)

    # pseudocode:
    # write_json(REPORTS_DIR / "summary.json", summary)
    print_console_summary(summary)

    return 0 if summary["failed_cases"] == 0 else 1


if __name__ == "__main__":
    raise SystemExit(main())
