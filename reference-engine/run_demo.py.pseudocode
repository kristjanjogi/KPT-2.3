def minimum_basis_codes_satisfied(actual_codes: list[str], expected_codes: list[str]) -> bool:
    """
    v0.1 rule:
    expected basis codes are minimum required basis codes,
    not necessarily the only allowed codes.
    """
    return set(expected_codes).issubset(set(actual_codes))


def enforcement_matches(actual: dict[str, Any], expected: dict[str, Any]) -> bool:
    """Compare enforcement outcome against expected enforcement contract."""
    required_keys = [
        "display_allowed",
        "display_mode",
        "execution_allowed",
        "execution_mode",
        "replacement_required",
    ]
    for key in required_keys:
        if actual.get(key) != expected.get(key):
            return False
    return True


def compare_case_result(case: dict[str, Any], actual: dict[str, Any]) -> dict[str, Any]:
    """
    Compare actual engine output to the canonical case contract.

    Must verify at minimum:
    - decision_state
    - minimum basis codes
    - qualification_type
    - enforcement outcome
    - trace_count
    """
    expected = case["expected"]

    actual_primary = actual["primary_decision"]
    actual_trace_count = actual["trace_count"]
    actual_enforcement = actual["final_enforcement"]

    checks = {
        "decision_state_match": actual_primary["decision_state"] == expected["decision_state"],
        "basis_codes_match": minimum_basis_codes_satisfied(
            actual_primary.get("basis_codes", []),
            expected.get("basis_codes", []),
        ),
        "qualification_type_match": actual_primary.get("qualification_type") == expected.get("qualification_type"),
        "enforcement_match": enforcement_matches(actual_enforcement, expected["enforcement"]),
        "trace_count_match": actual_trace_count == expected["trace_count"],
    }

    return {
        "case_id": case["case_id"],
        "title": case.get("title"),
        "checks": checks,
        "passed": all(checks.values()),
        "expected": expected,
        "actual_summary": {
            "decision_state": actual_primary.get("decision_state"),
            "basis_codes": actual_primary.get("basis_codes", []),
            "qualification_type": actual_primary.get("qualification_type"),
            "trace_count": actual_trace_count,
            "enforcement": actual_enforcement,
        },
    }


